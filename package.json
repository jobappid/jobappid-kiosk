{
  "name": "jobappid-kiosk",
  "version": "1.0.28",
  "main": "dist/main.js",
  "description": "JobAppID Kiosk",
  "author": "JobAppID",
  "private": true,
  "scripts": {
    "build": "tsc",
    "dev": "npm run build && electron .",
    "start": "npm run build && electron .",
    "rebuild": "electron-rebuild -f -w keytar",
    "pack": "npm run build && npm run rebuild && electron-builder --dir",
    "dist": "npm run build && npm run rebuild && electron-builder",
    "pack:linux": "npm run build && npm run rebuild && electron-builder --linux --arm64 --dir",
    "dist:linux": "npm run build && npm run rebuild && electron-builder --linux --arm64",
    "dist:pi": "npm run dist:linux",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "electron-updater": "^6.7.3",
    "keytar": "^7.9.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/node": "^22.0.0",
    "electron": "^40.1.0",
    "electron-builder": "^26.7.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "build": {
    "appId": "com.jobappid.kiosk",
    "productName": "JobAppID Kiosk",
    "asar": true,
    "asarUnpack": [
      "**/node_modules/keytar/**"
    ],
    "files": [
      "dist/**/*",
      "public/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "linux": {
      "category": "Utility",
      "icon": "build/icon.png",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "arm64"
          ]
        }
      ],
      "artifactName": "JobAppID-Kiosk-${version}-linux-${arch}.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "jobappid",
        "repo": "jobappid-kiosk",
        "releaseType": "release"
      }
    ]
  }
}
